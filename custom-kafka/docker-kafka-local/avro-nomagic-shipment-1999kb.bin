#!/usr/bin/env python3
"""
EventSmartKafka — Real Avro Binary Generator
Generates DECODABLE Avro binaries from order-event.avsc at target sizes.

Two outputs:
  1) avro-magic-1mb.bin   -> Confluent wire format: [0x00][4-byte schema id][avro body]  (~1 MB)
  2) avro-nomagic-2mb.bin -> RAW Avro binary, NO magic byte, NO schema id (~2 MB)

Both are REAL Avro encoded against the schema, so the adapter can actually decode them.
Payload size is hit by growing the lineItems array until the encoded body reaches target.

Requires: pip install fastavro
"""
import io, struct, json, uuid, random, time, os
import fastavro

SCHEMA_PATH = os.path.abspath(os.path.join(os.path.dirname(__file__), '..', 'payloads', 'avro', 'order-event.avsc'))
SCHEMA_ID   = 100011          # must match the ID you register in Confluent for the MAGIC file
MAGIC       = 0x00

def load_schema():
    with open(SCHEMA_PATH) as f:
        return fastavro.parse_schema(json.load(f))

def make_record(num_items):
    return {
        "eventId": str(uuid.uuid4()),
        "eventType": "ORDER_CREATED",
        "eventTimestamp": int(time.time() * 1000),
        "orderId": "ORD-" + str(random.randint(10**9, 10**10)),
        "customerId": "CUST-" + str(random.randint(10**6, 10**7)),
        "currency": "EUR",
        "totalAmount": round(random.uniform(100, 99999), 2),
        "status": "CREATED",
        "lineItems": [
            {
                "sku": "SKU-" + str(random.randint(10**5, 10**6)),
                "description": "Product line item with a reasonably descriptive text payload " + str(i),
                "quantity": random.randint(1, 50),
                "unitPrice": round(random.uniform(1, 500), 2),
                "lineTotal": round(random.uniform(1, 5000), 2),
                "warehouse": random.choice(["WH-LIS", "WH-MAD", "WH-FRA", "WH-AMS"]),
                "notes": ("batch note " + str(i)) if i % 3 == 0 else None,
            }
            for i in range(num_items)
        ],
        "metadata": {f"k{j}": f"value-{j}-{random.randint(0,9999)}" for j in range(8)},
    }

def encode_body(schema, record):
    """Single-object Avro binary encoding (no container header)."""
    buf = io.BytesIO()
    fastavro.schemaless_writer(buf, schema, record)
    return buf.getvalue()

def build_to_size(schema, target_bytes):
    """Grow lineItems until the encoded body is >= target_bytes."""
    n = 100
    while True:
        body = encode_body(schema, make_record(n))
        if len(body) >= target_bytes:
            return body, n
        # estimate how many more items needed
        per_item = max(1, len(body) // max(1, n))
        deficit = target_bytes - len(body)
        n += max(50, deficit // per_item + 50)

def main():
    schema = load_schema()

    # ── File 1: WITH magic byte, ~1 MB ────────────────────────────────────
    target1 = 1 * 1024 * 1024
    body1, items1 = build_to_size(schema, target1)
    header = struct.pack(">Bi", MAGIC, SCHEMA_ID)   # 0x00 + 4-byte schema id (big-endian)
    magic_file = header + body1
    with open(os.path.join(os.path.dirname(SCHEMA_PATH), 'avro-magic-1mb.bin'), 'wb') as f:
        f.write(magic_file)
    print(f"avro-magic-1mb.bin    : {len(magic_file):>10,} bytes  ({len(magic_file)/1024/1024:.3f} MB)  "
          f"items={items1}  header=auto schemaId={SCHEMA_ID}")

    # ── File 2: NO magic byte, ~2 MB ──────────────────────────────────────
    target2 = 2 * 1024 * 1024
    body2, items2 = build_to_size(schema, target2)
    with open(os.path.join(os.path.dirname(SCHEMA_PATH), 'avro-nomagic-2mb.bin'), 'wb') as f:
        f.write(body2)
    print(f"avro-nomagic-2mb.bin  : {len(body2):>10,} bytes  ({len(body2)/1024/1024:.3f} MB)  "
          f"items={items2}  NO header (raw schemaless Avro)")

    # ── Verify both decode back ───────────────────────────────────────────
    print("\nVerification (decode round-trip):")
    # magic: strip 5-byte header first
    r1 = fastavro.schemaless_reader(io.BytesIO(magic_file[5:]), schema)
    print(f"  magic-1mb   decoded OK : orderId={r1['orderId']} lineItems={len(r1['lineItems'])}")
    r2 = fastavro.schemaless_reader(io.BytesIO(body2), schema)
    print(f"  nomagic-2mb decoded OK : orderId={r2['orderId']} lineItems={len(r2['lineItems'])}")

if __name__ == "__main__":
    main()
