#!/usr/bin/env python3
"""Generate a REAL decodable ShipmentEvent Avro binary, ~2 MB, NO magic byte."""
import io, json, uuid, random, time
import fastavro

SCHEMA_PATH = os.path.abspath(os.path.join(os.path.dirname(__file__), '..', 'payloads', 'avro', 'shipment-event.avsc'))
TARGET = 2 * 1024 * 1024

with open(SCHEMA_PATH) as f:
    schema = fastavro.parse_schema(json.load(f))

def make_record(n_parcels):
    return {
        "shipmentId": str(uuid.uuid4()),
        "eventType": "SHIPMENT_DISPATCHED",
        "dispatchedAt": int(time.time() * 1000),
        "carrier": random.choice(["DHL", "UPS", "FedEx", "GLS", "DPD"]),
        "trackingNumber": "TRK-" + str(random.randint(10**11, 10**12)),
        "originHub": random.choice(["HUB-LIS", "HUB-MAD", "HUB-FRA"]),
        "destinationHub": random.choice(["HUB-AMS", "HUB-CDG", "HUB-LHR"]),
        "serviceLevel": random.choice(["STANDARD", "EXPRESS", "PRIORITY"]),
        "totalWeightKg": round(random.uniform(1, 5000), 2),
        "estimatedDeliveryDays": random.randint(1, 10),
        "parcels": [
            {
                "parcelId": "PCL-" + str(random.randint(10**6, 10**7)),
                "weightKg": round(random.uniform(0.1, 50), 2),
                "lengthCm": round(random.uniform(5, 120), 1),
                "widthCm": round(random.uniform(5, 80), 1),
                "heightCm": round(random.uniform(5, 80), 1),
                "contents": "Packaged goods description for parcel number " + str(i),
                "fragile": (i % 4 == 0),
                "customsValue": round(random.uniform(10, 9999), 2) if i % 2 == 0 else None,
            }
            for i in range(n_parcels)
        ],
        "routeStops": [random.choice(["LIS","MAD","BCN","FRA","AMS","CDG","LHR","MIL"]) for _ in range(6)],
        "labels": {f"label{j}": f"val-{random.randint(0,9999)}" for j in range(6)},
    }

def encode(rec):
    buf = io.BytesIO()
    fastavro.schemaless_writer(buf, schema, rec)
    return buf.getvalue()

n = 100
while True:
    body = encode(make_record(n))
    if len(body) >= TARGET:
        break
    per = max(1, len(body)//max(1,n))
    n += max(50, (TARGET-len(body))//per + 50)

with open(os.path.join(os.path.dirname(SCHEMA_PATH), 'avro-nomagic-shipment-2mb.bin'), 'wb') as f:
    f.write(body)

# verify decode
r = fastavro.schemaless_reader(io.BytesIO(body), schema)
print(f"avro-nomagic-shipment-2mb.bin : {len(body):,} bytes ({len(body)/1024/1024:.3f} MB) parcels={n}")
print(f"  decoded OK: shipmentId={r['shipmentId']} carrier={r['carrier']} parcels={len(r['parcels'])}")
print("  NO magic byte, NO schema id — use Fixed Schema ID mode in the channel.")
